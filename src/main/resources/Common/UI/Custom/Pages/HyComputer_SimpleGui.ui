            Visible: false;
          }

          $C.@SecondaryTextButton #Button15 {
            Text: "Button 15";
            Anchor: (Height: 60, Bottom: 10);
            TooltipText: "";
            Visible: false;
          }

          $C.@SecondaryTextButton #Button16 {
            Text: "Button 16";
